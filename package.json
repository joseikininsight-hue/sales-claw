{
  "name": "sales-claw",
  "version": "1.2.0",
  "description": "Automated B2B company outreach via web contact forms, powered by Claude, Codex, or Gemini CLI plus Playwright",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "dashboard": "node src/dashboard-server.cjs",
    "dashboard:restart": "node scripts/restart-dashboard.cjs",
    "electron": "electron .",
    "dist": "electron-builder --win --mac --linux",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "setup": "node -e \"const fs=require('fs');if(!fs.existsSync('data/settings.json'))fs.copyFileSync('data/sample-settings.json','data/settings.json');console.log('data/settings.json ready');\"",
    "test": "playwright test",
    "test:ui": "playwright test --headed",
    "test:report": "playwright show-report"
  },
  "keywords": [
    "outreach",
    "automation",
    "playwright",
    "claude-code",
    "codex",
    "gemini",
    "b2b",
    "sales"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron-updater": "^6.8.3",
    "node-pty": "^1.1.0",
    "playwright": "^1.58.2",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "extends": "./electron-builder.yml"
  }
}
