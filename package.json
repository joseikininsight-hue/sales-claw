{
  "name": "sales-claw",
  "version": "1.2.13",
  "description": "Automated B2B company outreach via web contact forms, powered by Claude, Codex, or Gemini CLI plus Playwright",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "dashboard": "node src/dashboard-server.cjs",
    "dashboard:preview": "node scripts/preview-dashboard.cjs",
    "dashboard:restart": "node scripts/restart-dashboard.cjs",
    "build:assets": "node scripts/build-assets.cjs",
    "verify:surface": "node scripts/verify-surface-parity.cjs",
    "verify:release": "node scripts/verify-release-readiness.cjs && node scripts/verify-surface-parity.cjs",
    "verify:dist": "node scripts/verify-release-readiness.cjs --dist && node scripts/verify-surface-parity.cjs",
    "verify:installed": "node scripts/verify-release-readiness.cjs --installed && node scripts/verify-surface-parity.cjs --installed",
    "install:win": "powershell -ExecutionPolicy Bypass -File scripts/install-latest-win.ps1",
    "lp:dev": "next dev -p 3000",
    "lp:build": "next build",
    "lp:start": "next start -p 3000",
    "electron": "electron .",
    "predist": "npm run verify:release",
    "postdist": "npm run verify:dist",
    "dist": "electron-builder --win --mac --linux",
    "predist:win": "npm run verify:release",
    "dist:win": "electron-builder --win",
    "postdist:win": "npm run verify:dist",
    "predist:mac": "npm run verify:release",
    "dist:mac": "electron-builder --mac",
    "predist:linux": "npm run verify:release",
    "dist:linux": "electron-builder --linux",
    "setup": "node -e \"const fs=require('fs');if(!fs.existsSync('data/settings.json'))fs.copyFileSync('data/sample-settings.json','data/settings.json');console.log('data/settings.json ready');\"",
    "test": "playwright test",
    "test:ui": "playwright test --headed",
    "test:report": "playwright show-report"
  },
  "keywords": [
    "outreach",
    "automation",
    "playwright",
    "claude-code",
    "codex",
    "gemini",
    "b2b",
    "sales"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@playwright/mcp": "^0.0.70",
    "electron-updater": "^6.8.3",
    "fs-extra": "^10.1.0",
    "lucide-react": "^1.9.0",
    "next": "^16.2.4",
    "node-pty": "^1.1.0",
    "npm": "^10.9.8",
    "playwright": "^1.58.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "universalify": "^2.0.1",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@phosphor-icons/web": "^2.1.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "chart.js": "^4.5.1",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "material-symbols": "^0.44.4",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "build": {
    "extends": "./electron-builder.yml"
  }
}
